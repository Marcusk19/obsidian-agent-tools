#!/usr/bin/env node
import { readFileSync } from "node:fs";
import { join } from "node:path";
import { execFile } from "node:child_process";

function readJsonInput() {
  try {
    const raw = readFileSync(0, "utf8");
    if (!raw) return {};
    const parsed = JSON.parse(raw);
    return typeof parsed === "object" && parsed !== null ? parsed : {};
  } catch {
    return {};
  }
}

function memoryTimeoutMs() {
  const configured = Number(process.env.OBSIDIAN_MEMORY_TIMEOUT_MS);
  return Number.isFinite(configured) && configured > 0 ? configured : 5_000;
}

function runContextCommand(prompt, cwd) {
  const executable = process.env.OBSIDIAN_AGENT_CONTEXT || join(process.env.HOME || "/tmp", ".local", "bin", "obsidian-agent-context");
  const args = [];
  if (cwd) args.push("--cwd", cwd);
  args.push(prompt);
  return new Promise((resolve, reject) => {
    execFile(
      executable,
      args,
      { timeout: memoryTimeoutMs(), maxBuffer: 20_000 },
      (error, stdout) => {
        if (error) reject(error);
        else resolve(stdout);
      },
    );
  });
}

async function main() {
  const payload = readJsonInput();
  const response = { ...payload };
  const prompt = typeof payload.prompt === "string" ? payload.prompt : "";
  const cwd = typeof payload.cwd === "string" && payload.cwd ? payload.cwd : undefined;
  let context = "";

  if (process.env.OBSIDIAN_MEMORY_ENABLED !== "0" && prompt.trim()) {
    try {
      context = (await runContextCommand(prompt, cwd)).trim();
    } catch {
      context = "";
    }
  }

  if (context) response.system_context = context;
  process.stdout.write(`${JSON.stringify(response)}\n`);
}

main().catch(() => {
  process.stdout.write("{}\n");
});
